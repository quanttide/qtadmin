#!/bin/bash
# pre-commit hook

STUDIO="src/studio"
CLI="src/cli"
PROVIDER="src/provider"

if git diff --cached --name-only | grep -q "^$STUDIO/"; then
  (cd "$STUDIO" && flutter pub get && dart analyze lib/ test/ && flutter test)
  rc=$?
  if [ $rc -ne 0 ]; then
    echo "✗ studio 检查失败，提交终止"
    exit 1
  fi
  echo "✓ studio 检查通过 (pub get, analyze, test)"
fi

if git diff --cached --name-only | grep -q "^$CLI/"; then
  (cd "$CLI" && cargo build)
  rc=$?
  if [ $rc -ne 0 ]; then
    echo "✗ cargo build 失败，提交终止"
    exit 1
  fi
  echo "✓ cargo build 通过"

  (cd "$CLI" && cargo test)
  rc=$?
  if [ $rc -ne 0 ]; then
    echo "✗ cargo test 失败，提交终止"
    exit 1
  fi
  echo "✓ cargo test 通过"
fi

if git diff --cached --name-only | grep -q "^$PROVIDER/"; then
  (cd "$PROVIDER" && go build ./cmd/server && go vet ./... && go test ./...)
  rc=$?
  if [ $rc -ne 0 ]; then
    echo "✗ provider 检查失败，提交终止"
    exit 1
  fi
  echo "✓ provider 检查通过 (build, vet, test)"
fi
